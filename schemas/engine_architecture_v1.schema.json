{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://master-all-strings.dev/schema/engine-architecture-v1.schema.json",
  "title": "Four-Engine Architecture Registry",
  "description": "Schema for the constitutional machine-readable governance source (governance/engine_architecture_v1.json).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authority", "engines", "dependency_rules", "capabilities", "contracts", "seam_assignments", "adr_assignments"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "authority": {"type": "string", "minLength": 1},
    "note": {"type": "string"},
    "engines": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "answers", "depends_on_none"],
        "properties": {
          "id": {"$ref": "#/$defs/engineId"},
          "name": {"type": "string", "minLength": 1},
          "answers": {"type": "string", "minLength": 1},
          "depends_on_none": {"type": "boolean"}
        }
      }
    },
    "dependency_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "relation"],
        "properties": {
          "from": {"$ref": "#/$defs/engineId"},
          "to": {"$ref": "#/$defs/engineId"},
          "relation": {"enum": ["depends", "consumes_evidence", "consumes_contracts", "prohibited"]}
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "owning_engine", "permitted_consumers", "classification", "implementation_status"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "name": {"type": "string", "minLength": 1},
          "owning_engine": {"$ref": "#/$defs/engineId"},
          "permitted_consumers": {"type": "array", "items": {"$ref": "#/$defs/engineId"}, "uniqueItems": true},
          "classification": {"$ref": "#/$defs/classification"},
          "primary_contract": {"type": "string", "minLength": 1},
          "implementation_status": {"enum": ["implemented", "partial", "planned"]}
        }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "owning_engine", "producer", "consumers", "mutability", "classification", "versioning_authority"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]*$"},
          "owning_engine": {"$ref": "#/$defs/engineId"},
          "producer": {"$ref": "#/$defs/engineId"},
          "consumers": {"type": "array", "items": {"$ref": "#/$defs/engineId"}, "uniqueItems": true},
          "mutability": {"enum": ["immutable", "versioned"]},
          "classification": {"$ref": "#/$defs/classification"},
          "cites": {"type": "string", "minLength": 1},
          "versioning_authority": {"$ref": "#/$defs/engineId"}
        }
      }
    },
    "seam_assignments": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["seam", "rule"],
        "properties": {
          "seam": {"type": "string", "minLength": 1},
          "rule": {"type": "string", "minLength": 1}
        }
      }
    },
    "adr_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adr", "title", "status"],
        "properties": {
          "adr": {"type": "string", "pattern": "^ADR-[0-9]{4}$"},
          "title": {"type": "string", "minLength": 1},
          "status": {"enum": ["reserved", "accepted", "proposed", "superseded"]},
          "owner": {"type": "string", "minLength": 1},
          "engine": {"oneOf": [{"$ref": "#/$defs/engineId"}, {"type": "null"}]}
        }
      }
    }
  },
  "$defs": {
    "engineId": {"enum": ["MUSICAL_CORE", "EDUCATIONAL_ENGINE", "CREATIVE_ENGINE", "PERFORMANCE_ENGINE"]},
    "classification": {"enum": ["evidence", "interpretation", "neither"]}
  }
}
